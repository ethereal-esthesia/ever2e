#!/bin/bash
set -euo pipefail
JVM_FRAME_CYCLE_OFFSET="${JVM_FRAME_CYCLE_OFFSET:-0}"

# 0) Regenerate JVM raw trace with current emulator code/flags
cd /Users/shane/Project/ever2e-jvm
GRADLE_USER_HOME=/private/tmp/gradle-home gradle --no-daemon runHeadless --args="ROMS/Apple2eForceMemtest.emu --steps 100000 --trace-file /private/tmp/jvm_phase12489_noreset.tr.csv --trace-phase pre --trace-start-pc 0xFA63 --display-phase-cycles 12489 --no-sound --reset-pflag-value 0x36 --reset-a-value 0x00 --reset-x-value 0x80 --reset-y-value 0x00 --reset-s-value 0xFD"

# 1) Rebuild JVM normalized CSV with the updated normalizer
python3 /Users/shane/Project/ever2e-py/tools/normalize_compare_csv.py \
  --kind jvm \
  --jvm-cycle-offset 2 \
  --jvm-frame-cycle-offset "${JVM_FRAME_CYCLE_OFFSET}" \
  --input /private/tmp/jvm_phase12489_noreset.tr.csv \
  --output /private/tmp/jvm_phase12489_noreset.compare.csv

# 2) (If needed) rebuild MAME normalized CSV
python3 /Users/shane/Project/ever2e-py/tools/normalize_compare_csv.py \
  --kind mame \
  --input /tmp/mame_force_small.csv \
  --output /tmp/mame_force_small.compare.csv

# 3) Compare 1-9
python3 /Users/shane/Project/ever2e-py/tools/compare_csv_side_by_side.py \
  --top /tmp/mame_force_small.compare.csv \
  --bottom /private/tmp/jvm_phase12489_noreset.compare.csv \
  --start-line 1 \
  --end-line 9
