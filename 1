#!/bin/bash
set -euo pipefail
STEP_RANGE="${STEP_RANGE:-${1:-1-9}}"
if [[ "${STEP_RANGE}" =~ ^([0-9]+)-([0-9]+)$ ]]; then
  START_LINE="${BASH_REMATCH[1]}"
  END_LINE="${BASH_REMATCH[2]}"
  if (( START_LINE < 1 )); then
    START_LINE=1
  fi
  if (( END_LINE < START_LINE )); then
    echo "error: STEP_RANGE end must be >= start (got ${STEP_RANGE})" >&2
    exit 1
  fi
else
  echo "error: STEP_RANGE must be <start-end>, e.g. 0-1000000 (got ${STEP_RANGE})" >&2
  exit 1
fi
DISPLAY_PHASE_CYCLES="${DISPLAY_PHASE_CYCLES:-12490}"
# In raw compare mode, default to +1 frame-cycle offset to align JVM panel phase with MAME.
# In legacy compare mode, retain the historical normalized start-near-00010 behavior.
JVM_FRAME_CYCLE_OFFSET="${JVM_FRAME_CYCLE_OFFSET:-}"
RAW_COMPARE="${RAW_COMPARE:-1}"
JVM_CYCLE_OFFSET="${JVM_CYCLE_OFFSET:-2}"
MAME_BIN="${MAME_BIN:-/Users/shane/Project/mame-alt/mame}"
MAME_ROMPATH="${MAME_ROMPATH:-}"
MAME_BASE_ROM_DIR="${MAME_BASE_ROM_DIR:-/Users/shane/Project/mame-alt/roms}"
MAME_FORCE_SET_ZIP="${MAME_FORCE_SET_ZIP:-${MAME_BASE_ROM_DIR}/apple2ep_force_memtest.zip}"
MAME_MACHINE="${MAME_MACHINE:-apple2ep}"
MAME_STEPS="${MAME_STEPS:-$END_LINE}"
MAME_TRACE="${MAME_TRACE:-/tmp/mame_force_small.tr}"
MAME_CSV="${MAME_CSV:-/tmp/mame_force_small.csv}"
MAME_TRACE_FLAGS="${MAME_TRACE_FLAGS:-noloop}"
MAME_TRACE_PROFILE="${MAME_TRACE_PROFILE:-}"
MAME_TRACE_ACTION="${MAME_TRACE_ACTION:-}"
MAME_RUNNER="${MAME_RUNNER:-/Users/shane/Project/ever2e-py/tools/run_mame_trace.sh}"
MAME_HEADLESS="${MAME_HEADLESS:-1}"
MAME_VIDEO="${MAME_VIDEO:-}"
MAME_WINDOW="${MAME_WINDOW:-}"
MAME_DEBUGGER="${MAME_DEBUGGER:-}"
MAME_SDL_VIDEODRIVER="${MAME_SDL_VIDEODRIVER:-}"

if [[ "${RAW_COMPARE}" == "1" ]]; then
  MAME_TRACE_PROFILE="${MAME_TRACE_PROFILE:-raw}"
  JVM_FRAME_CYCLE_OFFSET="${JVM_FRAME_CYCLE_OFFSET:-0}"
else
  JVM_FRAME_CYCLE_OFFSET="${JVM_FRAME_CYCLE_OFFSET:-$((10-DISPLAY_PHASE_CYCLES))}"
fi
MAME_TRACE_PROFILE="${MAME_TRACE_PROFILE:-basic}"

if [[ "${MAME_HEADLESS}" == "1" ]]; then
  MAME_VIDEO="${MAME_VIDEO:-none}"
  MAME_WINDOW="${MAME_WINDOW:-0}"
  MAME_DEBUGGER="${MAME_DEBUGGER:-none}"
  MAME_SDL_VIDEODRIVER="${MAME_SDL_VIDEODRIVER:-dummy}"
else
  MAME_VIDEO="${MAME_VIDEO:-soft}"
  MAME_WINDOW="${MAME_WINDOW:-1}"
  MAME_DEBUGGER="${MAME_DEBUGGER:-osx}"
fi

if [[ -z "${MAME_TRACE_ACTION}" ]]; then
  if [[ "${MAME_TRACE_PROFILE}" == "raw" ]]; then
    MAME_TRACE_ACTION='tracelog "TC=%08X C=%d BX=%d BY=%d FR=%d IR=%02X A=%02X,X=%02X,Y=%02X,P=%02X,S=%03X ",totalcycles,cycles,beamx,beamy,frame,ir,a,x,y,p,sp'
  else
    MAME_TRACE_ACTION='tracelog "TC=%08X A=%02X,X=%02X,Y=%02X,P=%02X,S=%03X ",totalcycles,a,x,y,p,sp'
  fi
fi

if [[ -z "${MAME_ROMPATH}" ]]; then
  MAME_ROMPATH="/tmp/mame_force_isolated_roms"
  mkdir -p "${MAME_ROMPATH}"
  if [[ ! -f "${MAME_ROMPATH}/apple2ep.zip" ]]; then
    if [[ -f "${MAME_FORCE_SET_ZIP}" ]]; then
      ln -sf "${MAME_FORCE_SET_ZIP}" "${MAME_ROMPATH}/apple2ep.zip"
    else
      echo "error: missing force ROM set zip: ${MAME_FORCE_SET_ZIP}" >&2
      exit 1
    fi
  fi
fi

# 0) Regenerate JVM raw trace with current emulator code/flags
cd /Users/shane/Project/ever2e-jvm
GRADLE_USER_HOME=/private/tmp/gradle-home gradle --no-daemon runHeadless --args="ROMS/Apple2eForceMemtest.emu --steps 100000 --trace-file /private/tmp/jvm_phase12489_noreset.tr.csv --trace-phase pre --trace-start-pc 0xFA63 --display-phase-cycles ${DISPLAY_PHASE_CYCLES} --no-sound --reset-pflag-value 0x36 --reset-a-value 0x00 --reset-x-value 0x80 --reset-y-value 0x00 --reset-s-value 0xFD"

# 1) Rebuild JVM normalized CSV with the updated normalizer
python3 /Users/shane/Project/ever2e-py/tools/normalize_compare_csv.py \
  --kind jvm \
  --jvm-cycle-offset "${JVM_CYCLE_OFFSET}" \
  --jvm-frame-cycle-offset "${JVM_FRAME_CYCLE_OFFSET}" \
  --input /private/tmp/jvm_phase12489_noreset.tr.csv \
  --output /private/tmp/jvm_phase12489_noreset.compare.csv

# 2) (If needed) rebuild MAME normalized CSV
#    Always recapture the MAME source CSV so compare inputs stay fresh.
MAME_BIN="${MAME_BIN}" \
MACHINE="${MAME_MACHINE}" \
ROMPATH="${MAME_ROMPATH}" \
STEPS="${MAME_STEPS}" \
TRACE_OUT="${MAME_TRACE}" \
CSV_OUT="${MAME_CSV}" \
CSV_DERIVE_RETRACE=0 \
CARDLESS=1 \
WINDOW="${MAME_WINDOW}" \
VIDEO="${MAME_VIDEO}" \
DEBUGGER="${MAME_DEBUGGER}" \
TRACE_FLAGS="${MAME_TRACE_FLAGS}" \
TRACE_ACTION="${MAME_TRACE_ACTION}" \
SDL_VIDEODRIVER="${MAME_SDL_VIDEODRIVER}" \
"${MAME_RUNNER}"

python3 /Users/shane/Project/ever2e-py/tools/normalize_compare_csv.py \
  --kind mame \
  --input "${MAME_CSV}" \
  --output /tmp/mame_force_small.compare.csv

# 3) Compare selected step/line window
python3 /Users/shane/Project/ever2e-py/tools/compare_csv_side_by_side.py \
  --top /tmp/mame_force_small.compare.csv \
  --bottom /private/tmp/jvm_phase12489_noreset.compare.csv \
  --start-line "${START_LINE}" \
  --end-line "${END_LINE}"
